---
import JsonLd from "@/components/JsonLd.astro";
import { site } from "@/data/site";
import CalculatorLayout from "@/layouts/CalculatorLayout.astro";

const pageUrl = `${site.url}/contact/thanks/`;
const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Contact confirmation",
  url: pageUrl,
  description: "Confirmation page for the Calc for Business contact form.",
  isPartOf: { "@type": "WebSite", name: site.name, url: site.url }
};
---

<CalculatorLayout
  title="Message Sent | Calc for Business"
  description="Confirmation page for the Calc for Business contact form."
>
  <Fragment slot="head">
    <JsonLd data={webPageSchema} />
  </Fragment>

  <section class="hero-card">
    <p class="eyebrow">Contact</p>
    <h1>Thanks. Your message was sent.</h1>
    <p class="hero-copy">
      We received your message and sent it to the inbox successfully.
    </p>
  </section>

  <section class="detail-grid">
    <article class="detail-card">
      <h2>What happens next</h2>
      <p>
        If you shared a calculator question, bug, or suggestion, it can be reviewed
        from there. You can head back to the toolkit any time.
      </p>

      <div class="form-actions">
        <a class="primary-button" href="/">Back to calculators</a>
        <a class="secondary-button" href="/contact/">Send another message</a>
      </div>
    </article>

    <article class="detail-card">
      <p class="disclaimer">{site.disclaimer}</p>
    </article>
  </section>
</CalculatorLayout>
