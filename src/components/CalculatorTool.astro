---
import FormulaBlock from "@/components/FormulaBlock.astro";
import FAQBlock from "@/components/FAQBlock.astro";
import MethodologyNote from "@/components/MethodologyNote.astro";
import RelatedTools from "@/components/RelatedTools.astro";
import ResultCard from "@/components/ResultCard.astro";
import type { ToolConfig, ToolField } from "@/lib/types";

interface Props {
  tool: ToolConfig;
}

const { tool } = Astro.props;

function getInputType(field: ToolField) {
  if (field.type === "currency" || field.type === "number") {
    return "number";
  }

  return field.type;
}

function inputClass(field: ToolField) {
  return field.width === "short" ? "input input--short" : "input input--medium";
}
---

<section class="hero-card">
  <p class="eyebrow">{tool.name}</p>
  <h1>{tool.name}</h1>
  <p class="hero-copy">{tool.intro}</p>
</section>

<section class="calculator-shell" data-calculator-root data-tool={tool.slug}>
  <div class="calculator-main">
    <form class="tool-form" data-calculator-form novalidate>
      {tool.sections.map((section) => (
        <fieldset class="form-section">
          <legend>{section.title}</legend>
          <p>{section.description}</p>
          <div class="field-grid">
            {section.fields.map((field) => {
              const fieldId = `${tool.slug}-${field.name}`;
              const errorId = `${fieldId}-error`;
              return (
                <div class="field-wrap">
                  <label class="field" for={fieldId}>
                    <span>{field.label}</span>
                  </label>
                  <div class:list={["input-shell", field.type === "select" && "input-shell--select", field.width === "short" ? "input-shell--short" : "input-shell--medium"]}>
                    {field.prefix && <span class="input-prefix">{field.prefix}</span>}
                    {field.type === "select" ? (
                      <select
                        id={fieldId}
                        class={inputClass(field)}
                        name={field.name}
                        required={field.required}
                        aria-describedby={`${field.help ? `${fieldId}-help ` : ""}${errorId}`.trim()}
                      >
                        {field.options.map((option) => (
                          <option value={option.value}>{option.label}</option>
                        ))}
                      </select>
                    ) : (
                      <input
                        id={fieldId}
                        class={inputClass(field)}
                        name={field.name}
                        type={getInputType(field)}
                        min={field.min}
                        step={field.step}
                        placeholder={field.placeholder}
                        required={field.required}
                        aria-describedby={`${field.help ? `${fieldId}-help ` : ""}${errorId}`.trim()}
                      />
                    )}
                    {field.suffix && <span class="input-suffix">{field.suffix}</span>}
                  </div>
                  {field.help && (
                    <small class="field-help" id={`${fieldId}-help`}>
                      {field.help}
                    </small>
                  )}
                  <small class="field-error" id={errorId} data-field-error={field.name} hidden></small>
                </div>
              );
            })}
          </div>
        </fieldset>
      ))}

      <div class="form-actions">
        <button type="submit" class="primary-button">Calculate</button>
        <button type="reset" class="secondary-button">Reset</button>
      </div>
      <p class="form-error" data-form-error hidden></p>
    </form>

    <ResultCard relatedTitle={tool.interpretationLabel} />
  </div>
</section>

<section class="detail-grid">
  <article class="detail-card">
    <div class="section-heading">
      <h2>How we calculate this</h2>
      <a class="text-link" href="/methodology/">See methodology</a>
    </div>
    <ol>
      {tool.methodology.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </article>

  <FormulaBlock formulas={tool.formulas} />
</section>

<section class="detail-grid">
  <article class="detail-card">
    <h2>{tool.example.title}</h2>
    <p>{tool.example.summary}</p>
    <ol>
      {tool.example.steps.map((step) => (
        <li>{step}</li>
      ))}
    </ol>
  </article>

  <FAQBlock faqs={tool.faqs} />
</section>

<section class="detail-grid">
  <MethodologyNote />
  <RelatedTools relatedTools={tool.relatedTools} />
</section>

<script>
  import "@/scripts/calculator-tool";
</script>
