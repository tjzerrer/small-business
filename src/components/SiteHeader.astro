---
import { homepageCategories } from "@/data/tools";
import { site } from "@/data/site";

const navSections = homepageCategories.map((category) => ({
  href: `/#${category.id}`,
  label:
    category.id === "pricing-profit"
      ? "Pricing & Profit"
      : category.id === "unit-economics"
        ? "Unit Economics"
        : "Marketing & Growth"
}));
---

<header class="site-header">
  <a class="brand" href="/">
    <span class="brand-mark">CB</span>
    <span>
      <strong>{site.shortName}</strong>
      <small>Fast math for small business decisions</small>
    </span>
  </a>

  <nav class="top-nav" aria-label="Primary">
    {navSections.map((section) => (
      <a href={section.href}>{section.label}</a>
    ))}
    <a href="/methodology/">Methodology</a>
    <a href="/contact/">Contact</a>
  </nav>
</header>
